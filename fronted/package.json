{
  "name": "fronted",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "check:ui-rules": "node scripts/check-time-format-consistency.mjs && node scripts/check-sort.mjs && node scripts/check-delete-confirm-consistency.mjs",
    "test:report": "node generate_test_report.mjs",
    "e2e": "playwright test",
    "e2e:headless": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:menu:smoke": "playwright test e2e/menu.smoke.spec.js",
    "e2e:menu:core": "playwright test e2e/menu.core.interactions.spec.js",
    "e2e:menu:light": "playwright test e2e/menu.light.actions.spec.js",
    "e2e:system:user": "playwright test e2e/user-role.management.spec.js --grep \"user management page\"",
    "e2e:system:role": "playwright test e2e/user-role.management.spec.js --grep \"role management page\"",
    "e2e:system:scheduler": "playwright test e2e/scheduler-sysconfig.spec.js --grep \"scheduler page\"",
    "e2e:system:sysconfig": "playwright test e2e/scheduler-sysconfig.spec.js --grep \"sysconfig page\"",
    "e2e:system:audit": "playwright test e2e/system.audit.spec.js",
    "e2e:assets:host": "playwright test e2e/assets.host-credential.spec.js --grep \"host management page\"",
    "e2e:assets:credential": "playwright test e2e/assets.host-credential.spec.js --grep \"credential management page\"",
    "e2e:automation:task": "playwright test e2e/automation.ops.spec.js --grep \"task page\"",
    "e2e:automation:logs": "playwright test e2e/automation.ops.spec.js --grep \"logs page\"",
    "e2e:automation:playbook": "playwright test e2e/automation.ops.spec.js --grep \"playbook page\"",
    "e2e:automation:inventory": "playwright test e2e/automation.ops.spec.js --grep \"inventory page\"",
    "e2e:automation:workflow": "playwright test e2e/automation.ops.spec.js --grep \"workflow page|workflow launch tooltip\"",
    "e2e:headed": "cross-env PW_HEADED=1 playwright test",
    "e2e:remote": "cross-env PW_SKIP_BACKEND_SERVER=1 playwright test",
    "e2e:remote:headed": "cross-env PW_SKIP_BACKEND_SERVER=1 PW_HEADED=1 playwright test",
    "e2e:headed:xvfb": "cross-env PW_HEADED=1 xvfb-run -a playwright test",
    "e2e:setup": "playwright test --project=setup",
    "e2e:codegen": "playwright codegen http://127.0.0.1:5173/login"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ansi_up": "^6.0.6",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.7.9",
    "fast-glob": "^3.3.2",
    "js-cookie": "^3.0.5",
    "jsencrypt": "^3.3.2",
    "qs": "^6.13.1",
    "sass": "^1.83.0",
    "sass-loader": "^16.0.4",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue": "^3.5.13",
    "vue-request": "^2.0.4",
    "vue-router": "^4.4.5",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "cross-env": "^7.0.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^0.34.6",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^22.1.0",
    "vite": "^6.0.1",
    "vite-plugin-vue-devtools": "^7.6.5",
    "vitest": "^0.34.6"
  }
}
